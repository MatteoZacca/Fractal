# ==========================================
# 1. Go Specifics
# ==========================================
# Compiled object files, binaries, and test files
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
bin/

# Dependency directories (we use go modules, so we don't commit vendor)
vendor/

# ==========================================
# 2. Windows Specifics
# ==========================================
# Windows image file caches
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db

# Folder config file
[Dd]esktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Windows Installer files
*.cab
*.msi
*.msix
*.msm
*.msp

# ==========================================
# 3. IDEs and Editors
# ==========================================
.vscode/
.idea/
*.swp
*~

# ==========================================
# 4. Distributed File System Specifics
# ==========================================
# Ignore the NameNode's local memory state file
namespace.json

# Ignore the DataNodes' local hard drives
data/
